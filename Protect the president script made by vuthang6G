local function GetConfig()
    local tool =
        LocalPlayer.Backpack:FindFirstChild(selectedTool)
        or
        (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(selectedTool))

    if not tool then
        warn(selectedTool, "not found")
        return nil
    end

    local success, cfg = pcall(function()
        return require(tool.Setting["1"])
    end)

    if not success or not cfg then
        warn("Failed to require config")
        return nil
    end

    local ok, err = pcall(function()
        setreadonly(cfg, false)
    end)

    if not ok then
        warn("setreadonly failed:", err)
    end

    return cfg
end

