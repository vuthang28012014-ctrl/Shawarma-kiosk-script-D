local AimConnection = RunService.RenderStepped:Connect(function()
    if FOVCircle_Drawing.Visible then
        FOVCircle_Drawing.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    end

    -- CHAY SONG SONG: He thong nao bat thi ngam theo he thong do, khong bi de len nhau
