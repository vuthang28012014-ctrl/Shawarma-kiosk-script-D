local function listenToBankEvents()
	local replicatedStorage = game:GetService("ReplicatedStorage")
	local remotesFolder = replicatedStorage:FindFirstChild("Remotes")
	local notificationEvent = remotesFolder and remotesFolder:FindFirstChild("NotiPotifcation")
	
	if notificationEvent and notificationEvent:IsA("RemoteEvent") then
		print("📡 [EVENT] Đang kết nối lắng nghe tín hiệu từ NotiPotifcation...")
		
		bankNotificationConnection = notificationEvent.OnClientEvent:Connect(function(statusType)
			if isBotRunning and statusType == "Open" then
				print("🔔 [EVENT] Nhận được tín hiệu 'Open'! Khởi động luồng Rob...")
				task.spawn(startBotProcess)
			end
		end)
	else
		warn("❌ Không tìm thấy RemoteEvent tại ReplicatedStorage.Remotes.NotiPotifcation!")
	end
end

