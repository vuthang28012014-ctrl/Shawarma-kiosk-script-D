							if playerData:FindFirstChild("FirstName") then playerData.FirstName.Changed:Connect(update) end
							if playerData:FindFirstChild("Gender") then playerData.Gender.Changed:Connect(update) end
							if playerData:FindFirstChild("Level") then playerData.Level.Changed:Connect(update) end
						end
					end
				end
				task.wait(1) -- Kiểm tra lại sau mỗi 1 giây để tránh lag
			end
		end)
	end

	if player.Character then onCharacterAdded(player.Character) end
	player.CharacterAdded:Connect(onCharacterAdded)
end

