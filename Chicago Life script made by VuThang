local function checkHasC4()
	local character = LocalPlayer.Character
	local backpack = LocalPlayer:FindFirstChild("Backpack")
	
	if character and character:FindFirstChild("C4") then return true end
	if backpack and backpack:FindFirstChild("C4") then return true end
	
