local function LayDanhSachSungTrongRuong()
   local DanhSachSung = {}
   
   local Backpack = LocalPlayer:FindFirstChild("Backpack")
   if Backpack then
      for _, Tool in pairs(Backpack:GetChildren()) do
         if Tool:IsA("Tool") and not table.find(DanhSachSung, Tool.Name) then
            table.insert(DanhSachSung, Tool.Name)
         end
      end
   end
   
   local Character = LocalPlayer.Character
   if Character then
      for _, Tool in pairs(Character:GetChildren()) do
         if Tool:IsA("Tool") and not table.find(DanhSachSung, Tool.Name) then
            table.insert(DanhSachSung, Tool.Name)
         end
      end
   end
   
   if #DanhSachSung == 0 then
      table.insert(DanhSachSung, "No weapons found!")
   end
   
   return DanhSachSung
end

-- Hàm kiểm tra vật cản (Wall Check)
local function KiemTraTuong(ViTriMucTieu, NhanVatMucTieu)
   if not WallCheckKichHoat then return true end -- Nếu tắt Wall Check thì luôn trả về đúng

   local ViTriCamera = Camera.CFrame.Position
   local HuongTia = (ViTriMucTieu - ViTriCamera)
   
   local ThamSoRaycast = RaycastParams.new()
   ThamSoRaycast.FilterType = Enum.RaycastFilterType.Exclude
   ThamSoRaycast.FilterDescendantsInstances = {LocalPlayer.Character, NhanVatMucTieu, Camera}
   ThamSoRaycast.IgnoreWater = true

   local KetQuaRaycast = workspace:Raycast(ViTriCamera, HuongTia, ThamSoRaycast)
   
   if not KetQuaRaycast then
      return true
   end
   return false
end

-- Hàm tìm mục tiêu gần tâm chuột nhất nằm trong vùng FOV và thỏa mãn Wall Check
local function LayMucTieuTrongFOV()
   local MucTieuGanNhat = nil
   local KhoangCachNhoNhat = BanKinhFOV

   for _, p in pairs(Players:GetPlayers()) do
      if p ~= LocalPlayer and p.Character then
         local Humanoid = p.Character:FindFirstChildOfClass("Humanoid")
         local RootPart = p.Character:FindFirstChild("HumanoidRootPart")
         local Head = p.Character:FindFirstChild("Head")
         
         if Humanoid and RootPart and Head and Humanoid.Health > 0 then
            local ViTriManHinh, TrenManHinh = Camera:WorldToViewportPoint(RootPart.Position)
            
            if TrenManHinh then
               local KhoangCachChuot = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(ViTriManHinh.X, ViTriManHinh.Y)).Magnitude
               if KhoangCachChuot < KhoangCachNhoNhat then
                  if KiemTraTuong(Head.Position, p.Character) then
                     MucTieuGanNhat = p.Character
                     KhoangCachNhoNhat = KhoangCachChuot
                  end
               end
            end
         end
      end
   end
   return MucTieuGanNhat
end

