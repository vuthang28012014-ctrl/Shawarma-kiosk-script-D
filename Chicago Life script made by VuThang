-- Hàm hỗ trợ tìm kiếm cấu hình Setting của khẩu súng đang chọn
local function getGunConfig(gunName)
    if not gunName then return nil, nil end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return nil, nil end
    
    local gun = backpack:FindFirstChild(gunName)
    if not gun then
        -- Tìm thêm trên tay nhân vật nếu lỡ đang cầm súng
        local char = LocalPlayer.Character
        if char then
            gun = char:FindFirstChild(gunName)
        end
    end
    
    if gun then
        local settingFolder = gun:FindFirstChild("Setting")
        if settingFolder then
            local configCommon = require(settingFolder)
            local config1 = nil
            local gunModule1 = settingFolder:FindFirstChild("1")
            if gunModule1 then
                config1 = require(gunModule1)
            end
            return configCommon, config1
        end
    end
    return nil, nil
end

-- Hàm cập nhật các tính năng dựa theo trạng thái hiện tại của các Toggle
local function applyGunModifications()
    if not SelectedGunName then return end
    
    local configCommon, config1 = getGunConfig(SelectedGunName)
    if not configCommon and not config1 then return end

    -- 1. Xử lý Toggle: Auto Reload (Tự động nạp đạn)
    if configCommon then
        configCommon.AutoReload = AutoReloadEnabled
    end

    -- 2. Xử lý Toggle: Auto Fire (Bắn tự động / Liên thanh)
    if config1 then
        config1.Auto = AutoFireEnabled
    end

    -- 3. Xử lý Toggle: Luôn luôn mát (Không nóng súng / Không sụt pin)
    if config1 then
        if AlwaysCoolEnabled then
            config1.BatteryEnabled = false
            config1.HeatPerFireMin = 0
            config1.HeatPerFireMax = 0
        else
            config1.BatteryEnabled = true
        end
    end

    -- 4. Xử lý Toggle: Không giật & Không nở tâm (No Recoil / Spread)
    if config1 then
        if NoRecoilEnabled then
            -- Sao lưu thông số gốc trước khi ghi đè (chỉ sao lưu lần đầu)
            if not OriginalRecoilSettings[SelectedGunName] then
                OriginalRecoilSettings[SelectedGunName] = {
                    Recoil = config1.Recoil,
                    Spread = config1.Spread,
                    CameraRecoilingEnabled = config1.CameraRecoilingEnabled,
                    ViewmodelRecoilInfluence = config1.ViewmodelRecoilInfluence,
                    AngleX_Min = config1.AngleX_Min,
                    AngleX_Max = config1.AngleX_Max,
                    AngleZ_Min = config1.AngleZ_Min,
                    AngleZ_Max = config1.AngleZ_Max
                }
            end

            -- Triệt tiêu hoàn toàn độ giật
            config1.Recoil = 0
            config1.Spread = 0
            config1.CameraRecoilingEnabled = false
            config1.ViewmodelRecoilInfluence = 0
            config1.AngleX_Min = 0
            config1.AngleX_Max = 0
            config1.AngleZ_Min = 0
            config1.AngleZ_Max = 0
        else
            -- Khôi phục lại thông số gốc nếu người dùng tắt Toggle
            local orig = OriginalRecoilSettings[SelectedGunName]
            if orig then
                config1.Recoil = orig.Recoil
                config1.Spread = orig.Spread
                config1.CameraRecoilingEnabled = orig.CameraRecoilingEnabled
                config1.ViewmodelRecoilInfluence = orig.ViewmodelRecoilInfluence
                config1.AngleX_Min = orig.AngleX_Min
                config1.AngleX_Max = orig.AngleX_Max
                config1.AngleZ_Min = orig.AngleZ_Min
                config1.AngleZ_Max = orig.AngleZ_Max
            end
        end
    end
end

-- Hàm quét nhanh Backpack để lấy danh sách tên các khẩu súng đang có
local function getBackpackGuns()
    local guns = {}
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, item in pairs(backpack:GetChildren()) do
            if item:IsA("Tool") and item:FindFirstChild("Setting") then
                table.insert(guns, item.Name)
            end
        end
    end
    -- Kiểm tra thêm súng đang cầm trên tay
    local char = LocalPlayer.Character
    if char then
        for _, item in pairs(char:GetChildren()) do
            if item:IsA("Tool") and item:FindFirstChild("Setting") then
                local exists = false
                for _, name in pairs(guns) do
                    if name == item.Name then exists = true break end
                end
                if not exists then
                    table.insert(guns, item.Name)
                end
            end
        end
    end
    
    if #guns == 0 then
        table.insert(guns, "Không tìm thấy súng trong balo!")
    end
    return guns
end

