        local targetPos = getManualTargetPosition()
        if targetPos then
            local targetCFrame = CFrame.new(Camera.CFrame.Position, targetPos)
            Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, Smoothness)
        end
    end
    
    if FOVAimEnabled_FOV then
        local targetPos = getFOVAimbotTarget_FOV()
        if targetPos then
            local targetCFrame = CFrame.new(Camera.CFrame.Position, targetPos)
            Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, Smoothness_FOV)
        end
    end
end)

