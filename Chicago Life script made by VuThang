						hpLabel.BackgroundTransparency = 1
						hpLabel.TextSize = 11
						hpLabel.Font = Enum.Font.SourceSansBold
						hpLabel.Parent = billboard

						-- Lắng nghe cập nhật thông tin liên tục
						local function update()
							local systemName = player.DisplayName or player.Name
							local fn = playerData and playerData:FindFirstChild("FirstName") and playerData.FirstName.Value or "Chưa rõ"
							local gd = playerData and playerData:FindFirstChild("Gender") and playerData.Gender.Value or "Chưa rõ"
							local lv = playerData and playerData:FindFirstChild("Level") and playerData.Level.Value or 0
							
							nameLabel.Text = systemName .. " | " .. tostring(fn)
							infoLabel.Text = tostring(gd) .. " | Lvl: " .. tostring(lv)
							hpLabel.Text = "HP: " .. math.floor(humanoid.Health)
							
							if (humanoid.Health / humanoid.MaxHealth) < 0.3 then
								hpLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
							else
								hpLabel.TextColor3 = Color3.fromRGB(85, 255, 85)
							end
						end
						
						update()
