----------------------------------------------------------------
-- 3. CODE LOGIC DI CHUYỂN XE (Chạy ngầm liên tục)
----------------------------------------------------------------
RunService.Heartbeat:Connect(function()
    if not BoostEnabled then return end
    
    local character = localPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildWhichIsA("Humanoid")
    if humanoid and humanoid.SeatPart and humanoid.SeatPart:IsA("VehicleSeat") then
        local seat = humanoid.SeatPart
        local vehicle = seat:FindFirstAncestorOfClass("Model")
        
        if vehicle then
            local currentPivot = vehicle:GetPivot()
            
            -- Tính góc xoay (Rẽ)
            local turnAngle = 0
            if seat.Steer == -1 then
                turnAngle = TURN_SPEED
            elseif seat.Steer == 1 then
                turnAngle = -TURN_SPEED
            end
            
            if turnAngle ~= 0 then
                currentPivot = currentPivot * CFrame.Angles(0, math.rad(turnAngle), 0)
            end
            
            -- Tính hướng tiến/lùi
            local moveDirection = 0
            if seat.Throttle == 1 then
                moveDirection = 1
            elseif seat.Throttle == -1 then
                moveDirection = -0.5
            end
            
            -- Cập nhật vị trí xe bằng PivotTo
            if moveDirection ~= 0 or turnAngle ~= 0 then
                local nextCFrame = currentPivot + (currentPivot.LookVector * (BoostSpeed * moveDirection))
                vehicle:PivotTo(nextCFrame)
            end
        end
    end
end)
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

-- Cấu hình thời gian giãn cách giữa các lần hồi giáp
local lastFireTime = 0 
local cooldownDuration = 1 

-- Biến toàn cục để kiểm soát trạng thái bật/tắt của chức năng
_G.AutoGodMode = false
local heartbeatConnection = nil

-- Hàm xử lý logic quét và hồi giáp độc lập
local function startGodModeLogic()
    if heartbeatConnection then return end -- Tránh chạy trùng lặp nhiều vòng lặp
    
    local safeZones = Workspace:WaitForChild("SafeZones", 10)
    if not safeZones then return end
    
    heartbeatConnection = RunService.Heartbeat:Connect(function()
        -- Nếu trạng thái chuyển thành false thì ngắt kết nối vòng lặp ngay lập tức
        if not _G.AutoGodMode then
            if heartbeatConnection then
                heartbeatConnection:Disconnect()
                heartbeatConnection = nil
            end
            return
        end
        
        local targetCharacter = Workspace:FindFirstChild("Hackerissomuch_20")
        if targetCharacter then
            local rootPart = targetCharacter:FindFirstChild("HumanoidRootPart")
            if rootPart then
                -- Kiểm tra ForceField
                local hasForceField = targetCharacter:FindFirstChildOfClass("ForceField") or targetCharacter:FindFirstChild("ForceField")
                
                -- NẾU MẤT GIÁP -> TIẾN HÀNH RESET VÀ KÍCH HOẠT LẠI
                if not hasForceField then
                    if os.clock() - lastFireTime >= cooldownDuration then
                        local children = safeZones:GetChildren()
                        local safePart = nil
                        
                        -- Lọc lấy Part ĐẦU TIÊN
                        for i = 1, #children do
                            local child = children[i]
                            if child:IsA("BasePart") and child.Name == "Part" then
                                local success, hasTouch = pcall(function()
                                    return child.TouchInterest
                                end)
                                if success and hasTouch then
                                    safePart = child
                                    break
                                end
                            end
                        end
                        
                        if safePart then
                            local fireTouchFunc = firetouchinterest or firetouchdetector
                            if fireTouchFunc then
                                lastFireTime = os.clock()
                                
                                task.spawn(function()
                                    -- Bước 1: Gửi lệnh Untouch (1)
                                    pcall(function()
                                        fireTouchFunc(safePart, rootPart, 1)
                                    end)
                                    
                                    task.wait(0.05)
                                    
                                    -- Bước 2: Gửi lại lệnh Touch (0)
                                    pcall(function()
                                        fireTouchFunc(safePart, rootPart, 0)
                                    end)
                                    
                                    print("🔥 [Rayfield] Đã tự động hồi lại giáp theo chu kỳ!")
                                end)
                            end
                        end
                    end
                end
            end
        end
    end)
end

