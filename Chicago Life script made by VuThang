	local connection
	connection = RunService.Heartbeat:Connect(function()
		if not isBotRunning then tween:Cancel() if connection then connection:Disconnect() end end
	end)
	
	tween:Play()
	tween.Completed:Wait()
	if connection then connection:Disconnect() end
	
	if not isBotRunning then return false end
	task.wait(0.2)
	return true
end

local function firePrompt(prompt)
    if not prompt or not isBotRunning then return end
    
    -- Nếu Executor có hàm chuyên dụng, dùng luôn để bypass Camera
    if fireproximityprompt then
        fireproximityprompt(prompt)
    else
        -- Phương án dự phòng cũ nếu Executor không hỗ trợ
        prompt.HoldDuration = 0
        prompt:InputHoldBegin()
        task.wait(0.05)
        prompt:InputHoldEnd()
    end
end

-- TIẾN TRÌNH ROB HOÀN CHỈNH
local function startBotProcess()
	print("🔓 [BOT] Bắt đầu chuỗi tiến trình Auto Rob Bank...")
	lockCameraToDirection(CURRENT_LOOK_VECTOR)
	task.wait(0.5)
	
	if not isBotRunning then return end
	local targets = getC4Targets()
	
	for i, target in ipairs(targets) do
		if not isBotRunning then break end
		
		-- Bước 1: Bay tới vị trí lấy bom C4
		if tweenToTarget(target.TargetPart) and isBotRunning then
			firePrompt(target.Prompt)
			print("💣 [BOT] Đã kích hoạt nhặt C4, đang kiểm tra trạng thái túi đồ...")
			
			-- BƯỚC SỬA LỖI: Vòng lặp chờ xác nhận C4 đã vào túi đồ (đợi tối đa 3 giây)
			local hasC4 = false
			for _ = 1, 30 do
				if not isBotRunning then break end
				if checkHasC4() then
					hasC4 = true
					break
				end
				task.wait(0.1) -- Kiểm tra lại sau mỗi 100ms
			end
			
			-- Nếu đã có C4 thì mới được phép chạy đến Ngân hàng để phá cửa
			if hasC4 and isBotRunning then
				print("✅ [BOT] Xác nhận đã sở hữu C4! Tiến hành di chuyển tới Cửa Ngân Hàng...")
				
				local bankPart, bankPrompt = getBankTarget()
				if bankPart and tweenToTarget(bankPart) and isBotRunning then
					equipC4Tool() -- Mang bom ra tay
					if bankPrompt and isBotRunning then
						firePrompt(bankPrompt) -- Đặt bom phá cửa
						
						for _ = 1, 60 do if not isBotRunning then break end task.wait(0.1) end -- Chờ két mở
						
						if not isBotRunning then break end
						updateCameraDirection(NEW_LOOK_VECTOR)
						task.wait(0.2)
						
						-- GOM TÀI SẢN (ĐẾM 5 LẦN)
						local fireCount = 0
						local cashList = getCashTargets()
						for _, cashData in ipairs(cashList) do
							if not isBotRunning or fireCount >= 5 then break end 
							if tweenToTarget(cashData.TargetPart) and isBotRunning then
								firePrompt(cashData.Prompt)
								fireCount = fireCount + 1
								task.wait(0.3)
							end
						end
						
						if isBotRunning and fireCount < 5 then
							local goldList = getGoldTargets()
							for _, goldData in ipairs(goldList) do
								if not isBotRunning or fireCount >= 5 then break end
								if tweenToTarget(goldData.TargetPart) and isBotRunning then
									firePrompt(goldData.Prompt)
									fireCount = fireCount + 1
									task.wait(0.3)
								end
							end
						end
						
						-- ĐI BÁN ĐỒ
						if not isBotRunning then break end
						updateCameraDirection(SELL_LOOK_VECTOR)
						task.wait(0.2)
						
						local sellPart, sellPrompt = getSellTarget()
						if sellPart and tweenToTarget(sellPart) and isBotRunning and sellPrompt then
							firePrompt(sellPrompt)
							print("✅ [BOT] Đã bán đồ xong! Đang chờ đợt tín hiệu tiếp theo...")
							task.wait(1)
						end
					end
				end
				break -- Thoát khỏi vòng lặp lấy bom khi đã thực hiện xong một chuỗi Rob thành công
			else
				warn("⚠️ [BOT] Lỗi: Kích hoạt nhặt bom nhưng server chưa cấp C4. Thử lại mục tiêu bom tiếp theo...")
			end
		end
	end
	resetCamera()
end

