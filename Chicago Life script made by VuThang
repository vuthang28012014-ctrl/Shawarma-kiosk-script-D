-- 1. Hàm quét bản đồ và SẮP XẾP XE THEO KHOẢNG CÁCH (Gần nhất xếp đầu)
local function findNearestRobbableVans()
    local targets = {}
    if not hrp then return targets end
    
    local myPosition = hrp.Position

    for _, object in pairs(workspace:GetChildren()) do
        if object.Name == "Robbable Van" then
            local stealModel = object:FindFirstChild("Steal Script") or object:FindFirstChild("StealScript")
            if stealModel then
                local brokenGlass = stealModel:FindFirstChild("Broken_glass")
                local scriptsFolder = stealModel:FindFirstChild("Scripts")
                local prompt = scriptsFolder and scriptsFolder:FindFirstChild("ProximityPrompt")
                
                if brokenGlass and prompt then
                    -- Tính toán khoảng cách từ nhân vật đến xe
                    local distance = (myPosition - brokenGlass.Position).Magnitude
                    table.insert(targets, {
                        Car = object,
                        Glass = brokenGlass,
                        Prompt = prompt,
                        Distance = distance -- Lưu lại khoảng cách để so sánh
                    })
                end
            end
        end
    end
    
    -- Sắp xếp danh sách xe: Xe nào khoảng cách nhỏ nhất (gần nhất) sẽ đứng đầu bảng
    table.sort(targets, function(a, b)
        return a.Distance < b.Distance
    end)
    
    return targets
end

-- 2. Hàm thực hiện di chuyển 3 chặng Tween
local function robTarget(target)
    if not AutoRobEnabled then return end
    if not humanoid or humanoid.Health <= 0 or not hrp then return end

    local p = Instance.new("BindableEvent")
    local camera = workspace.CurrentCamera
    
    -- CẤU HÌNH TỐC ĐỘ DI CHUYỂN
    local LiftSpeed = 15    
    local SafeSpeed = 100   -- Tốc độ bay ngang
    local LandSpeed = 12    
    local HeightOffset = 35 
    
    local startPos = hrp.Position
    local targetPos = target.Glass.Position
    local originalRotation = hrp.CFrame - hrp.Position
    
    local skyStartCFrame = CFrame.new(startPos.X, startPos.Y + HeightOffset, startPos.Z) * originalRotation
    local skyEndCFrame = CFrame.new(targetPos.X, targetPos.Y + HeightOffset, targetPos.Z) * originalRotation
    local finalLandingCFrame = target.Glass.CFrame
    
    local durationLift = HeightOffset / LiftSpeed
    local distanceHorizontal = (skyStartCFrame.Position - skyEndCFrame.Position).Magnitude
    local durationHorizontal = distanceHorizontal / SafeSpeed
    local durationVertical = HeightOffset / LandSpeed
    
    local cameraConnection
    local function startSmoothCamera()
        camera.CameraType = Enum.CameraType.Scriptable
        cameraConnection = RunService.RenderStepped:Connect(function()
            if hrp and character and humanoid and humanoid.Health > 0 then
                local targetCameraPos = hrp.Position + Vector3.new(0, 8, 12) 
                camera.CFrame = CFrame.new(targetCameraPos, hrp.Position)
            end
        end)
    end

    local function stopSmoothCamera()
        if cameraConnection then cameraConnection:Disconnect() end
        camera.CameraType = Enum.CameraType.Custom
    end

    local tween1, tween2, tween3
    local healthConnection
    
    -- Xử lý khi nhân vật bất ngờ bị chết/reset giữa đường bay
    healthConnection = humanoid.HealthChanged:Connect(function(health)
        if health <= 0 then
            stopSmoothCamera()
            if tween1 then tween1:Cancel() end
            if tween2 then tween2:Cancel() end
            if tween3 then tween3:Cancel() end
            if healthConnection then healthConnection:Disconnect() end
            p:Fire()
        end
    end)
    
    -- Xử lý ngắt Tween ngay lập tức nếu người dùng bấm TẮT Toggle giữa chừng
    local toggleCheckConnection
    toggleCheckConnection = RunService.Heartbeat:Connect(function()
        if not AutoRobEnabled then
            stopSmoothCamera()
            if humanoid then humanoid.PlatformStand = false end
            if tween1 then tween1:Cancel() end
            if tween2 then tween2:Cancel() end
            if tween3 then tween3:Cancel() end
            if healthConnection then healthConnection:Disconnect() end
            if toggleCheckConnection then toggleCheckConnection:Disconnect() end
            p:Fire()
        end
    end)
    
    startSmoothCamera()
    humanoid.PlatformStand = true
    
    -- CHẶNG 1: TWEEN BAY THẲNG LÊN TRỜI
    local tweenInfo1 = TweenInfo.new(durationLift, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    tween1 = TweenService:Create(hrp, tweenInfo1, {CFrame = skyStartCFrame})
    tween1:Play()
    
    tween1.Completed:Connect(function()
        if not AutoRobEnabled or humanoid.Health <= 0 then 
            if humanoid then humanoid.PlatformStand = false end
            stopSmoothCamera()
            p:Fire()
            return 
        end
        
        -- CHẶNG 2: TWEEN BAY NGANG TRÊN KHÔNG TRUNG (Tốc độ 100)
        local tweenInfo2 = TweenInfo.new(durationHorizontal, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
        tween2 = TweenService:Create(hrp, tweenInfo2, {CFrame = skyEndCFrame})
        tween2:Play()
        
        tween2.Completed:Connect(function()
            if not AutoRobEnabled or humanoid.Health <= 0 then 
                if humanoid then humanoid.PlatformStand = false end
                stopSmoothCamera()
                p:Fire()
                return 
            end
            
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            task.wait(0.05)
            
            -- CHẶNG 3: TWEEN HẠ CÁNH XUỐNG VỊ TRÍ XE
            local tweenInfo3 = TweenInfo.new(durationVertical, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
            tween3 = TweenService:Create(hrp, tweenInfo3, {CFrame = finalLandingCFrame})
            tween3:Play()
            
            tween3.Completed:Connect(function()
                if healthConnection then healthConnection:Disconnect() end
                if toggleCheckConnection then toggleCheckConnection:Disconnect() end
                
                if not AutoRobEnabled or humanoid.Health <= 0 then 
                    if humanoid then humanoid.PlatformStand = false end
                    stopSmoothCamera()
                    p:Fire()
                    return 
                end
                
                -- ĐÁP XE THÀNH CÔNG: ĐỨNG IM CHỜ ĐỒNG BỘ
                stopSmoothCamera()
                humanoid.PlatformStand = false
                hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0) 
                
                task.wait(1.0) -- Đứng im đúng 1 giây để ổn định vị trí trên x
                
                -- Bấm nút cướp xe
                for i = 1, 3 do
                    if not AutoRobEnabled or humanoid.Health <= 0 then break end
                    fireproximityprompt(target.Prompt)
                    task.wait(0.25)
                end
                
                p:Fire()
            end)
        end)
    end)
    
    p.Event:Wait()
end

