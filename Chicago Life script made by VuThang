local UpdateActive = true
task.spawn(function()
    while UpdateActive do
        pcall(function()
            if SelectedTargetName and not Players:FindFirstChild(SelectedTargetName) then
                SelectedTargetName = nil
            end
            
            local currentList = getPlayerNamesList()
            local currentPlayerCount = #currentList
            
            if currentPlayerCount ~= LastPlayerCount then
                LastPlayerCount = currentPlayerCount
                PlayerDropdown:Set(currentList)
            end
        end)
        task.wait(1)
    end
end)


