                boostUsed = true
                task.spawn(useBoosts)
            end

            task.spawn(function()

                while AutoFarmV2 do

                    local anomaly = findAnomaly()

                    if anomaly then
                        handleAnomaly(anomaly)

                    else
                        for _,pos in ipairs(stations) do

                            if not AutoFarmV2 then break end
                            
                            root.CFrame = CFrame.new(pos)
                            task.wait(0.3)

                            interactNearby(pos)

                        end
                    end

                    task.wait(0.2)

                end

            end)

        else
            boostUsed = false
        end
   end,
})
