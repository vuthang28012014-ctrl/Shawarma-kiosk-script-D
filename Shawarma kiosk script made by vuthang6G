	tool.RequiresHandle = false
	tool.Parent = backpack

	local playing = false
	local track = nil

	local function isR15(c)
		return c:FindFirstChild("UpperTorso") ~= nil
	end

	local function stopAnim()
		playing = false
		if track then
			track:Stop()
			track = nil
		end
	end

	tool.Equipped:Connect(function()
		playing = true
	end)

	tool.Unequipped:Connect(stopAnim)
	humanoid.Died:Connect(stopAnim)

	-- LOOP
	task.spawn(function()
