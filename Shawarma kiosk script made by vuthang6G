-------------------------------------------------
-- INTERACT (coffee + shawarma)
-------------------------------------------------

local function interactNearby(currentPos)

    local coffeePrompt = workspace.Cans.Coffee:FindFirstChildOfClass("ProximityPrompt")

    if coffeePrompt and coffeePrompt.Enabled then
        
        if not coffeeDone then

            local savedPos = currentPos

            root.CFrame = CFrame.new(coffeePos)
            task.wait(0.3)

            fireproximityprompt(coffeePrompt)
            coffeeDone = true

            task.wait(0.5)

            root.CFrame = CFrame.new(savedPos)
            task.wait(0.2)
        end

    else
        coffeeDone = false
    end

    for _,v in ipairs(workspace:GetDescendants()) do
        
        if v:IsA("ProximityPrompt") and v.Enabled then

            local action = (v.ActionText or ""):lower()

            if allowed[action] then
                fireproximityprompt(v)
                task.wait(0.35)
            end

        end

    end
end

-------------------------------------------------
-- HRP
-------------------------------------------------

local function getHRP(model)
    for _,v in ipairs(model:GetDescendants()) do
        if v:IsA("BasePart") and v.Name == "HumanoidRootPart" then
            return v
        end
    end
end

-------------------------------------------------
-- ANOMALY
-------------------------------------------------

local function findAnomaly()

    local hum = workspace:FindFirstChild("Hum")
    if not hum then return nil end

    for _,model in ipairs(hum:GetChildren()) do
        
        if not served[model]
        and not string.find(model.Name,"Man")
        and not string.find(model.Name,"Scream") then
            return model
        end
        
    end
end

local function handleAnomaly(model)

    local hrp = getHRP(model)
    if not hrp then return end

    repeat
        task.wait(0.1)
    until not model.Parent or (hrp.Position - doorPos).Magnitude < 5

    if not model.Parent then return end

    served[model] = true

    task.wait(1.5)

    root.CFrame = CFrame.new(-44,5,-548)
    task.wait(0.2)
    root.CFrame = CFrame.new(-38,5,-548)

    task.wait(10)

    fireproximityprompt(promptDoor)

    repeat
        task.wait(0.3)
    until not model.Parent or (hrp.Position - doorPos).Magnitude > 15

    fireproximityprompt(promptDoor)
end

