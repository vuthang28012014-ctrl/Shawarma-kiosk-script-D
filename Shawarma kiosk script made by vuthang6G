			task.wait()

			if not playing then continue end

			local r15 = isR15(char)

			if not track then
				local anim = Instance.new("Animation")
				anim.AnimationId = r15 and "rbxassetid://698251653" or "rbxassetid://72042024"
				track = humanoid:LoadAnimation(anim)
			end

			track:Play()
			track:AdjustSpeed(1)
			track.TimePosition = 0.57

			task.wait(0.1)

			while track and track.TimePosition < 0.6 do
				task.wait(0.1)
			end

			if track then
				track:Stop()
				track = nil
			end
		end
	end)
end

