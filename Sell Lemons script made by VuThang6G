local Toggle = Tab:CreateToggle({
    Name = "Auto Cheer",
    CurrentValue = false,
    Flag = "Toggle_SmoothCheer",
    Callback = function(Value)
        _G.SmoothCheer = Value

        if Value then
            task.spawn(function()
                local CollectionService = game:GetService("CollectionService")
                local LocalPlayer = game:GetService("Players").LocalPlayer
                local targetUIElement = nil

                while _G.SmoothCheer do
                    local taggedObjects = CollectionService:GetTagged("UI.MinigameRace")
                    local isRacing = false
                    
                    for _, guiInstance in ipairs(taggedObjects) do
                        if guiInstance:IsDescendantOf(LocalPlayer:FindFirstChild("PlayerGui")) then
                            local btn = guiInstance:FindFirstChild("Button")
                            if btn and btn.Visible and btn:FindFirstChild("Title") and btn.Title.Text == "Cheer" then
                                isRacing = true
                                break
                            end
                        end
                    end
                    
                    if isRacing then
                        if not targetUIElement then
                            for _, obj in ipairs(getgc(true)) do
                                if type(obj) == "table" and rawget(obj, "Cheered") and rawget(obj, "_TitleShowPrep") then
                                    if obj._Cheer == true then
                                        targetUIElement = obj
                                        break
                                    end
                                end
                            end
                        end
                        
                        if targetUIElement and targetUIElement._Cheer == true then
                            pcall(function()
                                targetUIElement.Cheered:Fire()
                            end)
                        end
                        
                        task.wait(0.04)
                    else
                        targetUIElement = nil
                        task.wait(0.5)
                    end
                end
            end)
        end
    end,
})
