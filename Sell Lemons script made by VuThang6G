local Section = Tab:CreateSection("Tycoon")
local Toggle = Tab:CreateToggle({
    Name = "Auto Buy Buttons",
    CurrentValue = false,
    Flag = "Toggle_AutoBuyButtons", 
    Callback = function(Value)
        _G.AutoBuyButtons = Value

        if Value then
            task.spawn(function()
                local Players = game:GetService("Players")
                local LocalPlayer = Players.LocalPlayer
                local BrokenButtons = {} 

                -- Hàm phân tách chuỗi tiền tệ thông minh (Chống nhận nhầm chữ trong tên nút)
                local function parseCurrency(textNum, textMag)
                    local cleanNum = string.gsub(string.lower(tostring(textNum)), "[^%d%.]", "")
                    local num = tonumber(cleanNum) or 0
                    
                    local mag = string.lower(tostring(textMag))
                    local rank = 1 
                    
                    -- Tách các từ riêng biệt bằng khoảng trắng để kiểm tra chính xác đơn vị viết tắt độc lập
                    local words = {}
                    for word in string.gmatch(mag, "%a+") do
                        table.insert(words, word)
                    end

                    -- Kiểm tra danh sách từ khóa đơn vị chuẩn
                    local function hasUnit(shortForm, longForm)
                        for _, w in ipairs(words) do
                            if w == shortForm or string.find(w, longForm) then
                                return true
                            end
                        end
                        return false
                    end
                    
                    if hasUnit("dc", "decillion") then rank = 12
                    elseif hasUnit("no", "nonillion") then rank = 11
                    elseif hasUnit("oc", "octillion") then rank = 10 
                    elseif hasUnit("sp", "septillion") then rank = 9
                    elseif hasUnit("sx", "sextillion") then rank = 8
                    elseif hasUnit("qi", "quintillion") then rank = 7
                    elseif hasUnit("qa", "quadrillion") then rank = 6
                    elseif hasUnit("t", "trillion") then rank = 5
                    elseif hasUnit("b", "billion") then rank = 4
                    elseif hasUnit("m", "million") then rank = 3
                    elseif hasUnit("k", "thousand") then rank = 2
                    end
                    
                    return { Num = num, Rank = rank, MagStr = mag }
                end
                
                -- Hàm lấy tiền từ ví chính xác
                local function getMyCashInfo()
                    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
                    local cashObj = leaderstats and leaderstats:FindFirstChild("Cash")
                    if not cashObj then return { Num = 0, Rank = 1, MagStr = "" } end
                    
                    local rawCash = cashObj.Value
                    if type(rawCash) == "number" then
                        return { Num = rawCash, Rank = 1, MagStr = "" }
                    end
                    
                    if type(rawCash) == "string" then
                        local numPart = string.match(rawCash, "[%d%.]+") or "0"
                        local magPart = string.gsub(rawCash, "[%d%.%s%$%,]", "")
                        return parseCurrency(numPart, magPart)
                    end
                    
                    return { Num = 0, Rank = 1, MagStr = "" }
                end

                -- Vòng lặp chính quét và tự động mua
                while _G.AutoBuyButtons do
                    if MeTycoon then
                        local myTycoonObj = workspace:FindFirstChild(MeTycoon)
                        
                        if myTycoonObj then
                            local validButtons = {}

                            for _, descendant in ipairs(myTycoonObj:GetDescendants()) do
                                if not _G.AutoBuyButtons then break end

                                if descendant:IsA("Model") then
                                    local fullPathLower = string.lower(descendant:GetFullName())
                                    
                                    if not string.match(fullPathLower, "gamepass") then
                                        local remoteFunc = descendant:FindFirstChild("Purchase")
                                        local buttonPart = descendant:FindFirstChild("Button")
                                        
                                        if remoteFunc and buttonPart then
                                            if not BrokenButtons[descendant] then
                                                local guiObj = buttonPart:FindFirstChild("Gui") or buttonPart:FindFirstChildOfClass("SurfaceGui") or buttonPart:FindFirstChildOfClass("BillboardGui")
                                                
                                                if guiObj then
                                                    local allText = ""
                                                    local textMagOnly = ""
                                                    for _, txtLabel in ipairs(guiObj:GetDescendants()) do
                                                        if txtLabel:IsA("TextLabel") and txtLabel.Text ~= "" then
                                                            local cleanText = string.lower(txtLabel.Text)
                                                            allText = allText .. " " .. cleanText
                                                            if not string.match(cleanText, "%d") then
                                                                textMagOnly = textMagOnly .. " " .. cleanText
                                                            end
                                                        end
                                                    end

                                                    if allText ~= "" and not string.find(allText, "robux") and not string.find(allText, "r$") then
                                                        local numPart = string.match(allText, "[%d%.]+") or "0"
                                                        local priceData = parseCurrency(numPart, textMagOnly)
                                                        
                                                        if priceData.Num > 0 then
                                                            table.insert(validButtons, {
                                                                Instance = descendant,
                                                                Remote = remoteFunc,
                                                                PriceInfo = priceData,
                                                                RawName = descendant.Name
                                                            })
                                                        end
                                                    end
                                                end
                                            end
                                        end
                                    end
                                end
                            end

                            if not _G.AutoBuyButtons then break end

                            -- Sắp xếp danh sách nút từ rẻ đến đắt
                            table.sort(validButtons, function(a, b)
                                if a.PriceInfo.Rank ~= b.PriceInfo.Rank then
                                    return a.PriceInfo.Rank < b.PriceInfo.Rank
                                else
                                    return a.PriceInfo.Num < b.PriceInfo.Num
                                end
                            end)

                            local myCashInfo = getMyCashInfo()

                            if #validButtons > 0 then
                                local cheapestButton = validButtons[1]
                                local pInfo = cheapestButton.PriceInfo
                                
                                local myNum   = tonumber(myCashInfo.Num) or 0
                                local myRank  = tonumber(myCashInfo.Rank) or 1
                                local btnNum  = tonumber(pInfo.Num) or 0
                                local btnRank = tonumber(pInfo.Rank) or 1

                                local canAfford = false
                                if myRank > btnRank then
                                    canAfford = true
                                elseif myRank == btnRank and myNum >= btnNum then
                                    canAfford = true
                                end

                                if canAfford then
                                    local success, result
                                    if cheapestButton.Remote:IsA("RemoteFunction") then
                                        success, result = pcall(function() 
                                            return cheapestButton.Remote:InvokeServer(false) 
                                        end)
                                    else
                                        success, result = pcall(function() 
                                            cheapestButton.Remote:FireServer(false) 
                                            return true 
                                        end)
                                    end
                                    
                                    if not success or (result == false) then
                                        BrokenButtons[cheapestButton.Instance] = true
                                    end
                                    task.wait(0.3)
                                end
                            else
                                BrokenButtons = {}
                            end
                        end
                    end

                    task.wait(1.2)
                end
            end)
        end
    end,
})
