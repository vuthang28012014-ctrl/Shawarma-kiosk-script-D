local MeTycoon = nil

-- Hàm quét và tìm kiếm Tycoon thuộc sở hữu của bạn
local function FindMyTycoon()
    for _, obj in ipairs(workspace:GetChildren()) do
        if string.match(obj.Name, "Tycoon") then
            local ownerObject = obj:FindFirstChild("Owner")
            
            if ownerObject then
                if ownerObject.Value == LocalPlayer.Name or (type(ownerObject.Value) == "userdata" and ownerObject.Value == LocalPlayer) then
                    
                    -- SET GIÁ TRỊ VÀO BIẾN CỦA PHẠM VI NGOÀI (Không ghi lại chữ local)
                    MyTycoonInstance = obj
                    MeTycoon = obj.Name 
                    
                    return obj
                end
            end
        end
    end
    
    return nil
end

