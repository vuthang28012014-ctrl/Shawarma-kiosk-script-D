}

local function affordProg(price, cur) local ok, r = pcall(function() return price ~= nil and price <= cur end) return ok and r end

local _rootCache, _earnCache = nil, {}
local function refreshEarnersCache(t)
    if not t or not t.Instance then return end
    if _rootCache == t.Instance and #_earnCache > 0 then return end
    _rootCache, _earnCache = t.Instance, {}
    for _, i in ipairs(CollectionService:GetTagged("Tycoon.Earner")) do 
        if i:IsDescendantOf(_rootCache) then table.insert(_earnCache, i) end 
    end
end

