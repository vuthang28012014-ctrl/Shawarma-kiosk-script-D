task.spawn(function()
    while true do
        local t = ProgTycoonModule and ProgTycoonModule.getLocal()
        if t then
            pcall(function()
                -- 1. Logic: Auto Upgrade Earners (Bulk) mua số lượng lớn bằng Cash
                if ProgState.AutoUpgradeEarners then
                    local bal = t:GetComponent(TycoonBalances)
                    if bal then
                        refreshEarnersCache(t)
                        for _, inst in ipairs(_earnCache) do
                            if not ProgState.AutoUpgradeEarners then break end
                            local e = Entity.getUnsafe(inst)
                            if e then
                                local okl, lvl = pcall(function() return e:GetUpgradeLevel() end)
                                if okl then
                                    local ok, price, count = pcall(function() 
                                        return e:GetUpgradePrice(lvl, math.huge, bal:GetCash()) 
                                    end)
                                    if ok and count and count > 0 then pcall(function() e:UpgradeAsync(count) end) end
                                end
                            end
                        end
                    end
                end

                -- 2. Logic: Auto Upgrade Powers
                if ProgState.AutoUpgradePowers then
                    local bal = t:GetComponent(ClientTycoonBalances)
                    local pw = t:GetComponent(ClientTycoonPowers)
                    if bal and pw and Config then
                        for name in pairs(Config.Powers) do
                            if not ProgState.AutoUpgradePowers then break end
                            local okl, lvl = pcall(function() return pw:GetLevel(name) end)
                            local okm, maxl = pcall(function() return pw:GetMaxLevel(name) end)
                            if okl and okm and maxl and lvl < maxl then
                                local okp, price = pcall(function() return pw:GetUpgradePrice(name) end)
                                local oki, inv = pcall(function() return bal:GetInvestors() end)
                                if okp and price and oki and affordProg(price, inv) then pcall(function() pw:UpgradeAsync(name) end) end
                            end
                        end
                    end
                end

                -- 3. Logic: Auto Rebirth
                if ProgState.AutoRebirth then
                    local rb = t:GetComponent(ClientTycoonRebirth)
                    if rb then
                        local ok, pot = pcall(function() return rb:GetPotentialInvestors() end)
                        if ok then
                            local cok, ready = pcall(function() return Huge.one < pot end)
                            if cok and ready then pcall(function() rb:RebirthAsync(false) end) end
                        end
                    end
                end

                -- 4. Logic: Auto Evolve
                if ProgState.AutoEvolve then
                    local ev = t:GetComponent(ClientTycoonEvolution)
                    if ev then
                        local ok, p = pcall(function() return ev:GetEvolutionProgress() end)
                        if ok and type(p) == "number" and p >= 1 then pcall(function() ev:EvolveAsync() end) end
                    end
                end

                -- 5. Logic: Auto Ascend
                if ProgState.AutoAscend then
                    local a = t:GetComponent(ClientTycoonAscension)
                    if a then
                        local okd, d = pcall(function() return a:IsDiscovered() end)
                        if okd and d then
                            local ok, p = pcall(function() return a:GetAscension() end)
                            if ok and type(p) == "number" and p >= 1 then pcall(function() a:AscendAsync() end) end
                        end
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)
