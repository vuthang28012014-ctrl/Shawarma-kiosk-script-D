local Toggle = Tab:CreateToggle({
    Name = "Auto Farm LemonTree",
    CurrentValue = false,
    Flag = "Toggle_AutoFarmTrees",
    Callback = function(Value)
        _G.AutoFarmTrees = Value

        if Value then
            task.spawn(function()
                local player = game:GetService("Players").LocalPlayer
                
                -- Hàm phụ: Xử lý farm cho một thư mục cây
                local function farmFolder(treesFolder)
                    if not treesFolder then return end
                    
                    for _, descendant in ipairs(treesFolder:GetDescendants()) do
                        if not _G.AutoFarmTrees then break end

                        if descendant:IsA("ClickDetector") then
                            local parentPart = descendant.Parent
                            
                            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and parentPart and parentPart:IsA("BasePart") then
                                -- 1. Teleport đến cây
                                player.Character.HumanoidRootPart.CFrame = parentPart.CFrame * CFrame.new(0, 2, 0)
                                task.wait(0.05)
                                
                                if not _G.AutoFarmTrees then break end
                                
                                -- 2. Click cây
                                fireclickdetector(descendant, 0)
                                
                                task.wait(0.5)
                            end
                        end
                    end
                end

                -- Vòng lặp chính của Toggle Auto Farm
                while _G.AutoFarmTrees do
                    
                    if _G.SelectedPlace == "Map" then
                        -- CHẾ ĐỘ MAP: Quét từ Tycoon1 đến Tycoon10
                        for i = 1, 10 do
                            if not _G.AutoFarmTrees then break end
                            
                            local tycoonName = "Tycoon" .. i
                            local tycoonObj = workspace:FindFirstChild(tycoonName)
                            local treesFolder = tycoonObj
                                and tycoonObj:FindFirstChild("Constant")
                                and tycoonObj.Constant:FindFirstChild("Trees")
                            
                            if treesFolder then
                                farmFolder(treesFolder)
                            end
                        end
                        
                    elseif _G.SelectedPlace == "My Slot" then
                        -- CHẾ ĐỘ MY SLOT: Nếu chưa tìm được tên nhà thì quét lại để phòng hờ
                        if not MeTycoon then
                            FindMyTycoon()
                        end

                        if MeTycoon then
                            -- 🛠️ ĐÃ SỬA CÚ PHÁP: Tìm vật thể bằng tên biến động trong ngoặc vuông []
                            local myTycoonObj = workspace:FindFirstChild(MeTycoon)
                            local treesFolder = myTycoonObj
                                and myTycoonObj:FindFirstChild("Constant")
                                and myTycoonObj.Constant:FindFirstChild("Trees")
                            
                            if treesFolder then
                                farmFolder(treesFolder)
                            end
                        end
                    end

                    task.wait(1)
                end
            end)
        end
    end,
})

