local Tab = Window:CreateTab("Gun Mods", 4483362458)
local selectedTool = nil

local function GetTools()
    local tools = {}
    if player:FindFirstChild("Backpack") then
        for _, v in ipairs(player.Backpack:GetChildren()) do
            if v:IsA("Tool") then table.insert(tools, v.Name) end
        end
    end
    if player.Character then
        for _, v in ipairs(player.Character:GetChildren()) do
            if v:IsA("Tool") then table.insert(tools, v.Name) end
        end
    end
    return tools
end


local ToolDropdown = Tab:CreateDropdown({
    Name = "Tools",
    Options = GetTools(),
    CurrentOption = "", 
    MultipleOptions = false,
    Flag = "ToolDropdown",
    Callback = function(Options)
        selectedTool = Options[1]
        print("Selected:", selectedTool)
    end,
})

local function RefreshTools()
    ToolDropdown:Refresh(GetTools())
end

local childAddedConn, childRemovedConn

local function SetupCharacterConnections(char)
    if childAddedConn then childAddedConn:Disconnect() end
    if childRemovedConn then childRemovedConn:Disconnect() end
    
    childAddedConn = char.ChildAdded:Connect(RefreshTools)
    childRemovedConn = char.ChildRemoved:Connect(RefreshTools)
    RefreshTools()
end

player.Backpack.ChildAdded:Connect(RefreshTools)
player.Backpack.ChildRemoved:Connect(RefreshTools)
player.CharacterAdded:Connect(SetupCharacterConnections)

if player.Character then
    SetupCharacterConnections(player.Character)
end

local function GetSelectedTool()
    if not selectedTool then return nil end
    return (player.Character and player.Character:FindFirstChild(selectedTool)) or player.Backpack:FindFirstChild(selectedTool)
end

Tab:CreateButton({
    Name = "Fast FireRate",
    Callback = function()
        local tool = GetSelectedTool()
        if not tool then warn("No tool selected") return end
        tool:SetAttribute("Auto", true)
        tool:SetAttribute("Cadence", 0)
    end,
})

Tab:CreateButton({
    Name = "No Recoil/Spread",
    Callback = function()
        local tool = GetSelectedTool()
        if not tool then warn("No tool selected") return end
        tool:SetAttribute("Recoil", 0)
    end,
})

local CurrentTaskId = 0
local function StartLoop(tool)
    CurrentTaskId = CurrentTaskId + 1
    local myId = CurrentTaskId

    task.spawn(function()
        while myId == CurrentTaskId do
            task.wait(0.25)
            if not tool or not tool.Parent then break end
            tool:SetAttribute("Ammo", math.huge)
        end
    end)
end

Tab:CreateButton({
    Name = "Inf Ammo",
    Callback = function()
        local tool = GetSelectedTool()
        if not tool then warn("No tool selected") return end
        tool:SetAttribute("MaxAmmo", math.huge)
        StartLoop(tool)
    end,
})
